{
  "word": "flash",
  "entries": [
    {
      "senses": [
        {
          "definition": "to shine brightly and suddenly, or to make something shine in this way",
          "features": "[ I or T ]",
          "translation": "（使）闪耀，（使）闪光",
          "examples": [
            {
              "sentence": "Stop flashing that light in my eyes!",
              "translation": "别拿那个手电筒晃我的眼睛了！"
            },
            {
              "sentence": "The lightning flashed and distant thunder rolled.",
              "translation": "电光闪过，远处雷声隆隆。"
            },
            {
              "sentence": "You'd better slow down, that car was flashing its lights at you.",
              "translation": "你最好减速，那辆车正朝你闪车灯呢。"
            }
          ]
        },
        {
          "definition": "If someone's eyes flash, they look bright because of the anger or excitement the person is feeling.",
          "features": "[ I ] literary",
          "translation": "（眼睛因愤怒或激动而）发亮，闪耀",
          "examples": []
        },
        {
          "definition": "to move very fast",
          "features": "[ I usually + adv/prep ]",
          "translation": "飞驰，掠过",
          "examples": [
            {
              "sentence": "They flashed past/by on a motorcycle.",
              "translation": "他们骑着摩托飞驰而过。"
            }
          ]
        },
        {
          "definition": "to show something for a short time",
          "features": "[ T ]",
          "translation": "（快速）出示，显示",
          "examples": [
            {
              "sentence": "He flashed a smile and offered to buy me a drink.",
              "translation": "他笑了一下，提出请我喝一杯。"
            }
          ]
        },
        {
          "definition": "If a man flashes, he shows his sexual organs in public.",
          "features": "[ I or T ] informal",
          "translation": "露阴，当众暴露性器官",
          "examples": [
            {
              "sentence": "He came out of the bushes and flashed me.",
              "translation": "他从灌木中出来，向我暴露私处。"
            }
          ]
        },
        {
          "definition": "to communicate something quickly, especially using radio or light waves",
          "features": "[ T usually + adv/prep ]",
          "translation": "（尤指用无线电或光波）通信，联络",
          "examples": [
            {
              "sentence": "Within moments of an event happening, the news can be flashed around the world.",
              "translation": "事件发生之后不久，消息就能迅速传遍世界。"
            }
          ]
        },
        {
          "definition": "If something flashes through/across your mind, you suddenly or quickly think of it.",
          "features": "[ I + adv/prep ]",
          "translation": "（想法等）突然闪现",
          "examples": [
            {
              "sentence": "The thought suddenly flashed through my mind that she didn't want to be here.",
              "translation": "我突然想到，她不想来这里。"
            }
          ]
        }
      ],
