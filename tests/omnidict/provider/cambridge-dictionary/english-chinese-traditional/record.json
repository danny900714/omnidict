          ]
        },
        {
          "definition": "If a device records a measurement, it shows that measurement.",
          "features": null,
          "translation": "（儀器）顯示，記錄，標明",
          "examples": [
            {
              "sentence": "The thermometer recorded a temperature of 30 degrees Celsius.",
              "translation": "溫度計顯示溫度是30攝氏度。"
